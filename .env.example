# =============================================================================
# RomaFront — variables de entorno (Vite)
# Copiá este archivo a `.env` y completá los valores reales.
# Nunca commitees `.env` (ya está en .gitignore).
# =============================================================================

# API del backend RomaBack (incluir /rrhh si el deploy lo usa)
VITE_API_DISTRI_API=http://localhost:3003/rrhh

# Dominio público de imágenes y archivos subidos por FTP
VITE_IMAGE_DOMAIN=http://www.ejemplo.com
VITE_IMAGE_PUBLIC_BASE_PATH=/remote/path
VITE_DEFAULT_USER_PHOTO_PATH=/images_rrhh/user-4250.png

# Certificados (panel admin reemplaza /external-files por esta base)
VITE_CERTIFICADOS_FILES_BASE_URL=https://externalfiles.ejemplo.com

# Enlaces externos de la home
VITE_NAPSIS_LOGIN_URL=https://sts.napsislatam.com/Account/Login
VITE_QR_HOME_URL=https://webservices.ejemplo.com/qrhome/index.html

# Firebase (cliente web + service worker)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
